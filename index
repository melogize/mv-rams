<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MV-Rams | Social Media & Kontakt</title>
    <style>
        :root {
            --bg-color: #0f172a; /* Dunkles Blau-Schwarz */
            --card-bg: #1e293b;  /* Etwas helleres Blau-Grau */
            --accent-color: #ef4444; /* Sportliches Rot */
            --text-color: #f8fafc;
            --button-hover: #dc2626;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 450px;
            background: var(--card-bg);
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            text-align: center;
        }

        .logo-area {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 10px;
            color: var(--accent-color);
            text-transform: uppercase;
        }

        h1 {
            font-size: 1.2rem;
            margin-bottom: 30px;
            opacity: 0.9;
            font-weight: 400;
        }

        .links-wrapper {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .link-item {
            display: block;
            padding: 16px;
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-color);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1.1rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .link-item:hover {
            background: var(--accent-color);
            border-color: var(--accent-color);
            transform: translateY(-2px);
        }

        .mail-item {
            margin-top: 10px;
            background: transparent;
            border: 2px dashed rgba(255, 255, 255, 0.2);
        }

        .footer {
            margin-top: 40px;
            font-size: 0.8rem;
            opacity: 0.5;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="logo-area">MV RAMS</div>
        <h1>Verbinde dich mit uns</h1>
        
        <div class="links-wrapper">
            <a href="https://www.facebook.com/groups/3014475398861708" target="_blank" class="link-item">
                Facebook Gruppe
            </a>

            <a href="https://www.instagram.com/mv_rams/" target="_blank" class="link-item">
                Instagram
            </a>

            <a href="https://www.tiktok.com/@mv.rams" target="_blank" class="link-item">
                TikTok
            </a>

            <a href="mailto:info@mv-rams.de" class="link-item mail-item">
                📧 E-Mail schreiben
            </a>
        </div>

        <div class="footer">
            &copy; 2026 MV-Rams | Bad Doberan
        </div>
    </div>

</body>
</html>
